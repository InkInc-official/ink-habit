{
  "name": "ink-habit",
  "version": "2.0.0",
  "description": "Ink Habit — 活動記録・過集中防止ツール by Ink Inc.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux"
  },
  "build": {
    "appId": "app.inkinc.inkhabit",
    "productName": "Ink Habit",
    "copyright": "© 2026 Ink Inc.",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "python/**",
      "assets/**"
    ],
    "extraResources": [
      { "from": "python", "to": "python", "filter": ["**/*"] }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ink Habit"
    },
    "deb": {
      "depends": ["python3", "libnotify-bin"]
    }
  },
  "dependencies": {
    "electron-auto-launch": "^5.0.5",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
